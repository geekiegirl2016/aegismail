{
  "name": "@aegismail/providers",
  "version": "0.0.0",
  "private": true,
  "description": "Provider adapters for Microsoft Graph (Outlook), Gmail, and IMAP (iCloud/Fastmail/etc).",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./graph": {
      "types": "./dist/graph/index.d.ts",
      "import": "./dist/graph/index.js"
    },
    "./gmail": {
      "types": "./dist/gmail/index.d.ts",
      "import": "./dist/gmail/index.js"
    },
    "./imap": {
      "types": "./dist/imap/index.d.ts",
      "import": "./dist/imap/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@aegismail/core": "workspace:*",
    "imapflow": "^1.0.187",
    "mailparser": "^3.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.5",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
