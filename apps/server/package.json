{
  "name": "@aegismail/server",
  "version": "0.0.0",
  "private": true,
  "description": "AegisMail backend: Fastify HTTP API and MCP server.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -b",
    "package": "node scripts/package.mjs",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist dist-deploy .turbo"
  },
  "dependencies": {
    "@aegismail/core": "workspace:*",
    "@aegismail/providers": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.1.0",
    "keytar": "^7.9.0",
    "pino": "^9.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@vercel/ncc": "^0.38.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
