{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AegisMail",
  "version": "0.0.0",
  "identifier": "org.aegismail.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @aegismail/desktop dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @aegismail/desktop build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AegisMail",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:8787"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Unified mail client",
    "longDescription": "AegisMail is a unified, privacy-respecting mail client for Outlook, Gmail, and iCloud/Apple Mail.",
    "copyright": "Copyright © 2026 AegisMail contributors",
    "resources": ["resources/server/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
