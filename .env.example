# Copy to .env and fill in. Never commit real secrets.

# Server
AEGIS_SERVER_PORT=8787
AEGIS_SERVER_HOST=127.0.0.1
AEGIS_LOG_LEVEL=info

# Microsoft Graph (Outlook) — OAuth app registration
MS_GRAPH_CLIENT_ID=
MS_GRAPH_TENANT=common
MS_GRAPH_REDIRECT_URI=http://127.0.0.1:8787/oauth/ms/callback

# Google (Gmail) — OAuth client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8787/oauth/google/callback

# iCloud / JMAP
JMAP_ENDPOINT=https://api.fastmail.com/jmap/session
JMAP_USERNAME=
JMAP_APP_PASSWORD=
