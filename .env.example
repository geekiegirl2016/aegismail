# Copy to .env and fill in. Never commit real secrets.
# This file is loaded automatically by `pnpm --filter @aegismail/server dev`.

# --- Server ---
AEGIS_SERVER_HOST=127.0.0.1
AEGIS_SERVER_PORT=8787
AEGIS_LOG_LEVEL=info

# --- Google (Gmail) — OAuth client ---
# Register a "Desktop app" OAuth client at https://console.cloud.google.com
# See docs/oauth-setup.md for the step-by-step.
AEGIS_GOOGLE_OAUTH_CLIENT_ID=
AEGIS_GOOGLE_OAUTH_CLIENT_SECRET=

# --- Microsoft (Outlook) — OAuth client (Phase 11) ---
# Register at https://entra.microsoft.com
# AEGIS_MS_OAUTH_CLIENT_ID=
